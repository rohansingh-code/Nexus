# Example environment configuration for Nexus project
# Copy this file to .env and replace placeholders with actual credentials.

# --- Database (Postgres) ---
POSTGRES_DB=hospital_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password

# --- Spring Boot Datasource ---
DB_URL=jdbc:postgresql://postgres:5432/hospital_db
DB_USERNAME=postgres
DB_PASSWORD=your_secure_password

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Security ---
JWT_SECRETKEY=your_very_long_and_secure_jwt_secret_key

# --- AI Service (Groq) ---
GROQ_API_KEY=your_groq_api_key_here

# --- Service Discovery / Networking ---
AI_SERVICE_URL=http://hospital-ai:8081
HOSPITAL_SERVICE_URL=http://hospital-app:8080
